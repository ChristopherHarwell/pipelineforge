# ── full-sdlc ──────────────────────────────────────────────
# Generated by pipelineforge sync --generate-lobster
# Each step spawns an OpenClaw agent inside a container.
# Agent configs (model, tools, sandbox) live in openclaw.json.

name: full-sdlc
description: "Full SDLC pipeline: requirements → tickets → implementation → review"

args:
  feature:
    description: "Feature description or user story"
  repo_dir:
    description: "Target repository directory"
  notes_dir:
    description: "Notes/docs output directory"
  gateway_url:
    default: "http://127.0.0.1:18789"
    description: "OpenClaw gateway URL"
  skill_dir:
    default: "~/.claude/skills"
    description: "Path to Claude Code skill definitions"

env:
  CLAUDECODE: ""
  ANTHROPIC_API_KEY: ""

steps:
  - id: project-init
    run: >
      openclaw agent
      --agent project-init
      -m
      "$(cat ~/.claude/skills/project-init/SKILL.md)
      
      ## Feature
      ${feature}
      
      ## Repository
      ${repo_dir}
      
      ## Notes
      ${notes_dir}
      "
      --json

  - id: assign-tickets
    run: >
      openclaw agent
      --agent assign-tickets
      -m
      "$(cat ~/.claude/skills/assign-tickets/SKILL.md)
      
      ## Feature
      ${feature}
      
      ## Repository
      ${repo_dir}
      
      ## Notes
      ${notes_dir}
      
      ## Prior Output
      $project-init.stdout
      "
      --json
    stdin: $project-init.json

  - id: implement-ticket
    run: >
      openclaw agent
      --agent implement-ticket
      -m
      "$(cat ~/.claude/skills/implement-ticket/SKILL.md)
      
      ## Feature
      ${feature}
      
      ## Repository
      ${repo_dir}
      
      ## Notes
      ${notes_dir}
      
      ## Prior Output
      $assign-tickets.stdout
      "
      --json
    stdin: $assign-tickets.json

  - id: qa-review
    run: >
      openclaw agent
      --agent qa-review
      -m
      "$(cat ~/.claude/skills/qa-review/SKILL.md)
      
      ## Feature
      ${feature}
      
      ## Repository
      ${repo_dir}
      
      ## Notes
      ${notes_dir}
      
      ## Prior Output
      $implement-ticket.stdout
      "
      --json
    stdin: $implement-ticket.json

  - id: type-review
    run: >
      openclaw agent
      --agent type-review
      -m
      "$(cat ~/.claude/skills/type-review/SKILL.md)
      
      ## Feature
      ${feature}
      
      ## Repository
      ${repo_dir}
      
      ## Notes
      ${notes_dir}
      
      ## Prior Output
      $qa-review.stdout
      "
      --json
    stdin: $qa-review.json

  - id: security-review
    run: >
      openclaw agent
      --agent security-review
      -m
      "$(cat ~/.claude/skills/security-review/SKILL.md)
      
      ## Feature
      ${feature}
      
      ## Repository
      ${repo_dir}
      
      ## Notes
      ${notes_dir}
      
      ## Prior Output
      $type-review.stdout
      "
      --json
    stdin: $type-review.json

  - id: staff-review
    run: >
      openclaw agent
      --agent staff-review
      -m
      "$(cat ~/.claude/skills/staff-review/SKILL.md)
      
      ## Feature
      ${feature}
      
      ## Repository
      ${repo_dir}
      
      ## Notes
      ${notes_dir}
      
      ## Prior Output
      $security-review.stdout
      "
      --json
    stdin: $security-review.json

  - id: approve-staff-review
    approval:
      prompt: "staff-review complete. Approve to continue?"
    stdin: $staff-review.json

  - id: vp-review
    run: >
      openclaw agent
      --agent vp-review
      -m
      "$(cat ~/.claude/skills/vp-review/SKILL.md)
      
      ## Feature
      ${feature}
      
      ## Repository
      ${repo_dir}
      
      ## Notes
      ${notes_dir}
      
      ## Prior Output
      $staff-review.stdout
      "
      --json
    stdin: $staff-review.json
    when: $approve-staff-review.approved

  - id: approve-vp-review
    approval:
      prompt: "vp-review complete. Approve to continue?"
    stdin: $vp-review.json

